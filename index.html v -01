                      <tbody>{[...filteredExp].reverse().map((ex,i)=>(
                        <tr key={ex.id}>
                          <TD c={formatDate(ex.date)} i={i}/>
                          <TD c={ex.desc} i={i}/>
                          <TD c={ex.category||"সাধারণ"} i={i}/>
                          <TD c={`৳${bn(ex.amount)}`} i={i} bold/>
                          <td style={{padding:"8px 10px",background:i%2===0?C.w:"#f5fbf7"}}>
