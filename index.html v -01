            <div style={{display:"flex",gap:10}}>
              <button onClick={()=>setEditSvc(null)} style={{...bs(false),flex:1}}>বাতিল</button>
              <button onClick={confirmAdd} style={{...bs(true),flex:1}}>✅ যোগ করুন</button>
            </div>
          </div>
        </div>
      )}

