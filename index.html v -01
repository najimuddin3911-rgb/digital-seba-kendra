      {toast&&(
        <div style={{position:"fixed",bottom:24,left:"50%",transform:"translateX(-50%)",background:C.g,color:"#fff",padding:"12px 24px",borderRadius:30,fontSize:14,fontWeight:600,zIndex:400,boxShadow:"0 4px 20px rgba(26,77,46,0.38)",whiteSpace:"nowrap"}}>
