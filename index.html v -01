function LiveClock(){
  const [now,setNow]=useState(new Date());
  useEffect(()=>{const t=setInterval(()=>setNow(new Date()),1000);return()=>clearInterval(t);},[]);
  const pad=n=>String(n).padStart(2,'0');
  const h=pad(now.getHours()),m=pad(now.getMinutes()),s=pad(now.getSeconds());
  const days=["রবিবার","সোমবার","মঙ্গলবার","বুধবার","বৃহস্পতিবার","শুক্রবার","শনিবার"];
  const months=["জানুয়ারি","ফেব্রুয়ারি","মার্চ","এপ্রিল","মে","জুন","জুলাই","আগস্ট","সেপ্টেম্বর","অক্টোবর","নভেম্বর","ডিসেম্বর"];
  return(
    <div style={{background:`linear-gradient(135deg,${C.g},${C.gl})`,borderRadius:16,padding:"18px 20px",color:"#fff",display:"flex",alignItems:"center",justifyContent:"space-between",gap:12,flexWrap:"wrap"}}>
      <div>
        <div style={{fontSize:11,opacity:0.7,marginBottom:4}}>{days[now.getDay()]}, {now.getDate()} {months[now.getMonth()]} {now.getFullYear()}</div>
        <div style={{fontSize:32,fontWeight:700,letterSpacing:2,fontVariantNumeric:"tabular-nums"}}>
          {h}<span className="clock-dot">:</span>{m}<span style={{fontSize:20,opacity:0.8}}>:{s}</span>
        </div>
      </div>
      <div style={{textAlign:"right"}}>
        <div style={{fontSize:11,opacity:0.7,marginBottom:4}}>আজকের তারিখ</div>
        <div style={{fontSize:14,fontWeight:600}}>{now.toLocaleDateString("bn-BD",{day:"numeric",month:"long",year:"numeric"})}</div>
      </div>
    </div>
  );
}

// ক্যালেন্ডার
function MiniCalendar({transactions}){
  const [cur,setCur]=useState(()=>{const d=new Date();return{y:d.getFullYear(),m:d.getMonth()};});
  const today=new Date();
  const months=["জানুয়ারি","ফেব্রুয়ারি","মার্চ","এপ্রিল","মে","জুন","জুলাই","আগস্ট","সেপ্টেম্বর","অক্টোবর","নভেম্বর","ডিসেম্বর"];
  const days=["রবি","সোম","মঙ্গ","বুধ","বৃহ","শুক্র","শনি"];
  const firstDay=new Date(cur.y,cur.m,1).getDay();
  const daysInMonth=new Date(cur.y,cur.m+1,0).getDate();
  // যে তারিখগুলোতে লেনদেন আছে
  const txDates=new Set(transactions.filter(tx=>{
    const d=new Date(tx.date);
    return d.getFullYear()===cur.y&&d.getMonth()===cur.m;
  }).map(tx=>new Date(tx.date).getDate()));

  const cells=[];
  for(let i=0;i<firstDay;i++)cells.push(null);
  for(let d=1;d<=daysInMonth;d++)cells.push(d);

  const prev=()=>setCur(c=>c.m===0?{y:c.y-1,m:11}:{y:c.y,m:c.m-1});
  const next=()=>setCur(c=>c.m===11?{y:c.y+1,m:0}:{y:c.y,m:c.m+1});

  return(
    <div style={{background:C.w,border:`1.5px solid ${C.b}`,borderRadius:16,padding:"16px",overflow:"hidden"}}>
      <div style={{display:"flex",alignItems:"center",justifyContent:"space-between",marginBottom:12}}>
        <button onClick={prev} style={{background:"none",border:`1px solid ${C.b}`,borderRadius:7,width:28,height:28,cursor:"pointer",fontSize:13,color:C.g}}>‹</button>
        <span style={{fontWeight:700,fontSize:14,color:C.g}}>{months[cur.m]} {cur.y}</span>
        <button onClick={next} style={{background:"none",border:`1px solid ${C.b}`,borderRadius:7,width:28,height:28,cursor:"pointer",fontSize:13,color:C.g}}>›</button>
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:2,marginBottom:6}}>
        {days.map(d=><div key={d} style={{textAlign:"center",fontSize:10,fontWeight:600,color:C.m,padding:"3px 0"}}>{d}</div>)}
      </div>
      <div style={{display:"grid",gridTemplateColumns:"repeat(7,1fr)",gap:2}}>
        {cells.map((d,i)=>{
          if(!d)return<div key={i}/>;
          const isToday=d===today.getDate()&&cur.m===today.getMonth()&&cur.y===today.getFullYear();
          const hasTx=txDates.has(d);
          return(
            <div key={i} className={`cal-day${hasTx?" cal-day-has-tx":""}`}
              style={{textAlign:"center",fontSize:12,padding:"5px 2px",cursor:"default",fontWeight:isToday?700:400,background:isToday?C.g:"transparent",color:isToday?"#fff":C.t,borderRadius:isToday?"50%":"4px",position:"relative"}}>
              {d}
            </div>
          );
        })}
      </div>
      <div style={{marginTop:10,display:"flex",gap:12,fontSize:11,color:C.m}}>
        <span><span style={{display:"inline-block",width:8,height:8,borderRadius:"50%",background:C.g,marginRight:4}}/>আজ</span>
        <span><span style={{display:"inline-block",width:8,height:8,borderRadius:"50%",background:C.goldf,marginRight:4}}/>লেনদেন আছে</span>
      </div>
    </div>
  );
}

